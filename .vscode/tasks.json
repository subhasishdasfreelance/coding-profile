{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "quick commit",
      "type": "shell",
      "command": "git add . && git commit -m \"wip\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "squash last wip commits",
      "type": "shell",
      "command": "N=$(git log --pretty=format:%s | sed -n '/^[Ww][Ii][Pp]/p' | wc -l); if [ \"$N\" -lt 1 ]; then echo \"No consecutive wip commits\"; exit 0; fi; git reset --soft HEAD~$N",
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}